docs/private/
.private/
*.private.*
secrets/
.env
.env.local
.env.*.local

# === Wiki staging (локальное зеркало fincore-engine.wiki.git, не коммитим в основной репо) ===
wiki/
# Клон вики-репо, если он лежит внутри папки основного репо (вложенный git, не коммитим)
fincore-engine.wiki/

# === Content staging (статьи/блог/newsletter/talks для itiana.dev — отдельный репо) ===
content/

# === Design staging (макеты/экспорты UI — WIP под Epic-08, не публикуем пока) ===
design/

